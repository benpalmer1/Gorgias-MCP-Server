# Required: Your Gorgias subdomain (e.g., "mycompany", "mycompany.gorgias.com", or "https://mycompany.gorgias.com")
GORGIAS_DOMAIN=mycompany

# Required: Email address of the Gorgias API user
GORGIAS_EMAIL=admin@mycompany.com

# Required: REST API key (Settings > REST API in Gorgias)
GORGIAS_API_KEY=your-api-key-here

# Optional: Access level — controls which tools are exposed to the AI
# Values: readonly | agent | admin (default: admin)
# Recommended: start with "readonly" for analytics/reporting, "agent" for support chatbots
GORGIAS_ACCESS_LEVEL=readonly
